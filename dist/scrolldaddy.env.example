# ScrollDaddy DNS Server — Environment Configuration
# Copy to /etc/scrolldaddy/scrolldaddy.env and edit before starting the service.
# Permissions: chown root:scrolldaddy /etc/scrolldaddy/scrolldaddy.env && chmod 640 /etc/scrolldaddy/scrolldaddy.env

# ── Database ──────────────────────────────────────────────────────────────────
SCD_DB_HOST=localhost
SCD_DB_PORT=5432
SCD_DB_NAME=your_database_name
SCD_DB_USER=scrolldaddy_dns
SCD_DB_PASSWORD=your_password_here

# ── Server Ports ──────────────────────────────────────────────────────────────
# DoH: Caddy/nginx should proxy HTTPS 443 → this port
SCD_DOH_PORT=8053
SCD_DOT_PORT=853

# ── DNS-over-TLS (leave blank to disable DoT) ─────────────────────────────────
# Requires a wildcard cert for *.{SCD_DOT_BASE_DOMAIN}
SCD_DOT_CERT_FILE=
SCD_DOT_KEY_FILE=
SCD_DOT_BASE_DOMAIN=

# ── Upstream DNS Resolvers ────────────────────────────────────────────────────
SCD_UPSTREAM_PRIMARY=1.1.1.1:53
SCD_UPSTREAM_SECONDARY=8.8.8.8:53

# ── Cache Reload Intervals ────────────────────────────────────────────────────
# Device/filter data reload interval in seconds
SCD_RELOAD_INTERVAL=60
# Blocklist domain reload interval in seconds
SCD_BLOCKLIST_RELOAD_INTERVAL=3600

# ── API Key ───────────────────────────────────────────────────────────────────
# Protects /device/{uid}/seen, /device/{uid}/log, /reload, /cache/flush
# Leave blank to allow all requests (only safe if port 8053 is firewall-restricted)
SCD_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
# Level: debug, info, warn, error
SCD_LOG_LEVEL=info
# Destination: stdout (captured by journald) or an absolute file path
SCD_LOG_FILE=/var/log/scrolldaddy/dns.log

# ── Peer Server ───────────────────────────────────────────────────────────────
# Base URL of the peer DNS server's API for log merging across instances.
# Leave blank for single-server mode (no peer features).
# Example: http://10.0.0.2:8053
SCD_PEER_URL=

# ── Feature Config ────────────────────────────────────────────────────────────
# Path to JSON feature config file (dns cache, query logging toggles)
# Defaults to /etc/scrolldaddy/dns.json if not set
# SCD_CONFIG_FILE=/etc/scrolldaddy/dns.json
